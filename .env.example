# Provider keys no son obligatorias en este archivo.
# Configuralas como variables del sistema operativo
# (por ejemplo: GROQ_API_KEY, OPENROUTER_API_KEY, MISTRAL_API_KEY, etc.)
# o cargalas desde el panel en Service keys.

PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug
PRETTY_LOGS=1
API_SECRET=                # Opcional: token maestro legacy para llamadas Bearer
ROUTER_MASTER_KEY=         # Obligatorio en produccion: 32 bytes hex/base64 para cifrar service keys
ROUTER_DB_PATH=            # Opcional: ruta personalizada para SQLite, util en tests y entornos separados
RESPONSE_CACHE_ENABLED=1   # Cache de respuestas para chat no-stream
RESPONSE_CACHE_BACKEND=hybrid
RESPONSE_CACHE_TTL_SECONDS=300
